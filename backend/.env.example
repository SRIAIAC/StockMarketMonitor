# Indian watchlist (Yahoo Finance NSE symbols): 20 large-cap, 15 mid-cap, 15 small-cap
WATCHLIST=RELIANCE.NS,HDFCBANK.NS,TCS.NS,ICICIBANK.NS,BHARTIARTL.NS,INFY.NS,HINDUNILVR.NS,ITC.NS,LT.NS,SBIN.NS,AXISBANK.NS,KOTAKBANK.NS,MARUTI.NS,SUNPHARMA.NS,TMPV.NS,TATASTEEL.NS,NTPC.NS,POWERGRID.NS,ULTRACEMCO.NS,ASIANPAINT.NS,CGPOWER.NS,DIXON.NS,COFORGE.NS,PERSISTENT.NS,MPHASIS.NS,CDSL.NS,IEX.NS,CYIENT.NS,GLENMARK.NS,BIRLACORPN.NS,FEDERALBNK.NS,AUBANK.NS,PIIND.NS,DEEPAKNTR.NS,SRF.NS,TRENT.NS,PAGEIND.NS,VOLTAS.NS,INDHOTEL.NS,LTTS.NS,CAMS.NS,KPITTECH.NS,RAINBOW.NS,CLEAN.NS,ANGELONE.NS,ROUTE.NS,LATENTVIEW.NS,HAPPSTMNDS.NS,GRANULES.NS,RATNAMANI.NS

# Anthropic (used sparingly - only for signals that pass rule thresholds)
ANTHROPIC_API_KEY=

# Local Ollama — free fallback for the /api/chat MAS assistant when
# ANTHROPIC_API_KEY is unset. Requires `ollama serve` running locally with
# OLLAMA_MODEL pulled (`ollama pull llama3.2`). If unreachable, chat falls
# further back to a keyword-based reply — never a broken endpoint.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# News (free RSS feeds are used by default; NewsAPI key is optional, free tier)
NEWSAPI_KEY=

# Poll intervals in minutes
PRICE_POLL_MINUTES=15
NEWS_POLL_MINUTES=60
SOCIAL_POLL_MINUTES=60

# SQLite db path
DATABASE_URL=sqlite:///./market_monitor.db
